<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="240.0" prefWidth="320.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="CharacterRemover_3.CharacterRemoverController">
   <children>
      <Label fx:id="textLabel" layoutX="32.0" layoutY="47.0" text="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789" />
      <CheckBox fx:id="vowelCheckbox" layoutX="32.0" layoutY="92.0" mnemonicParsing="false" text="Vowels" />
      <CheckBox fx:id="consonantCheckbox" layoutX="118.0" layoutY="92.0" mnemonicParsing="false" text="Consonants" />
      <CheckBox fx:id="numberCheckbox" layoutX="224.0" layoutY="92.0" mnemonicParsing="false" text="Numbers" />
      <Button fx:id="removeButton" layoutX="132.0" layoutY="135.0" mnemonicParsing="false" onAction="#remove" text="Remove" />
      <Button fx:id="restoreButton" layoutX="132.0" layoutY="180.0" mnemonicParsing="false" onAction="#restore" text="Restore" />
   </children>
</AnchorPane>
